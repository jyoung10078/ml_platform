# AWS credentials — use an IAM user/role with least-privilege access.
# WARNING: These values are bundled into the client-side JS. For production,
# prefer AWS Cognito Identity Pools or a backend proxy for credential management.

VITE_AWS_REGION=us-east-1
VITE_AWS_ACCESS_KEY_ID=
VITE_AWS_SECRET_ACCESS_KEY=
# Optional — for temporary credentials (STS / Cognito)
VITE_AWS_SESSION_TOKEN=

# Required only for the "Start Training" form submission:
VITE_SAGEMAKER_ROLE_ARN=arn:aws:iam::123456789012:role/SageMakerExecutionRole
VITE_SAGEMAKER_IMAGE_URI=382416733822.dkr.ecr.us-east-1.amazonaws.com/xgboost:latest
VITE_S3_BUCKET=your-ml-bucket-name
